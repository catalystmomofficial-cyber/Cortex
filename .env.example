# ---------------------------------------------------------------------------
# Cortex environment variables
# ---------------------------------------------------------------------------

# Speechmatics API key — used ONLY by the serverless function
# (api/speechmatics-token.js) to mint short-lived browser tokens.
# Never exposed to the client. Set this in Vercel → Project → Settings →
# Environment Variables, and in a local .env.local for `vercel dev`.
SPEECHMATICS_API_KEY=your-speechmatics-api-key-here

# Google Gemini API key — used ONLY by the serverless function (api/gemini.js)
# to power the advisor. Never exposed to the client; there is no key field in
# the UI. Get a free key at https://aistudio.google.com/app/apikey and set it
# in Vercel → Project → Settings → Environment Variables (and .env.local for
# `vercel dev`).
GEMINI_API_KEY=your-gemini-api-key-here

# VoxCPM voice (optional premium TTS). Cortex's api/tts.js forwards to your
# VoxCPM endpoint (e.g. a Modal deploy — see server/voxcpm_modal.py). Leave
# unset to use the free browser voice.
VOXCPM_URL=
VOXCPM_TOKEN=
# Client build flag: set to 1 to route the advisor's voice through VoxCPM.
# Unset / 0 = free browser voice.
VITE_VOXCPM=0
